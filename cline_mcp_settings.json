{
  "mcpServers": {
    "github.com/microsoft/playwright-mcp": {
      "type": "stdio",
      "command": "npx",
      "timeout": 30,
      "args": ["-y", "@playwright/mcp@latest"],
      "disabled": false,
      "autoApprove": []
    },
    "testsprite": {
      "type": "stdio",
      "command": "npx",
      "timeout": 60,
      "args": ["-y", "@testsprite/mcp-server@latest"],
      "env": {
        "TESTSPRITE_API_KEY": "${TESTSPRITE_API_KEY}"
      },
      "disabled": false,
      "autoApprove": []
    }
  }
}
