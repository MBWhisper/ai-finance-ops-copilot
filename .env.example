# ============================================================
# SUPABASE
# ============================================================
# Get these from: https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ============================================================
# DATABASE
# ============================================================
# Direct Postgres URL (used by Drizzle ORM)
# Get from: Supabase Dashboard → Project Settings → Database → Connection string
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# ============================================================
# STRIPE
# ============================================================
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# Get from: Stripe Dashboard → Developers → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# ============================================================
# ENCRYPTION
# ============================================================
# AES-256 key used to encrypt/decrypt stored Stripe API keys.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# MUST be exactly 64 hex characters (32 bytes). Keep this secret — rotating it
# will invalidate all stored encrypted keys.
ENCRYPTION_KEY=your-64-char-hex-encryption-key-here

# ============================================================
# EMAIL (Resend)
# ============================================================
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_...
# The "from" address shown in AR reminder emails.
# Must be a verified domain in your Resend account.
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ============================================================
# VERCEL CRON SECURITY
# ============================================================
# Shared secret that Vercel sends in the Authorization header for cron jobs.
# Generate with: openssl rand -hex 32
# Set the same value in: Vercel Dashboard → Project → Settings → Environment Variables
CRON_SECRET=your-cron-secret-here

# ============================================================
# APP
# ============================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
