# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Database (Supabase Pooler)
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# Lemon Squeezy (Primary billing provider)
LEMONSQUEEZY_API_KEY=your-lemonsqueezy-api-key
LEMONSQUEEZY_STORE_ID=your-store-id
LEMONSQUEEZY_WEBHOOK_SECRET=your-webhook-secret
LEMONSQUEEZY_STARTER_VARIANT_ID=1046512
LEMONSQUEEZY_GROWTH_VARIANT_ID=1046520
LEMONSQUEEZY_SCALE_VARIANT_ID=1046525

# Stripe (Legacy — optional, still works for data sync)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Encryption (32-byte hex: run `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`)
ENCRYPTION_KEY=your-32-byte-hex-encryption-key-here

# Email (Resend)
RESEND_API_KEY=re_...

# OpenAI
OPENAI_API_KEY=sk-...

# Upstash Redis (required for distributed rate limiting on /api/copilot)
# Create a free database at https://console.upstash.com/
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token-here

# Vercel Cron
CRON_SECRET=

# Google Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
